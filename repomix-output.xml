<file path="Dockerfile">
# ── Etapa 1: Build ───────────────────────────────────────────────────────────
FROM eclipse-temurin:21-jdk AS buildstage

RUN apt-get update && apt-get install -y maven

WORKDIR /app

# Copiar dependencias primero para aprovechar cache de Docker
COPY pom.xml .
RUN mvn dependency:go-offline -B

# Copiar código fuente
COPY src /app/src

# Compilar y empaquetar (sin tests para agilizar el pipeline)
RUN mvn clean package -DskipTests

# ── Etapa 2: Runtime ─────────────────────────────────────────────────────────
FROM eclipse-temurin:21-jdk

WORKDIR /app

# Copiar solo el .jar generado desde la etapa de build
COPY --from=buildstage /app/target/plataforma-educativa-0.0.1-SNAPSHOT.jar /app/app.jar

# Exponer el puerto del microservicio
EXPOSE 8080

# Comando de arranque
ENTRYPOINT ["java", "-jar", "/app/app.jar"]
</file>

